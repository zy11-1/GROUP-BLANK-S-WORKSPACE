    admin: [
      { id: 'admin-dashboard', icon: 'dashboard', label: 'Manage' },
      { id: 'student-map', icon: 'map', label: 'Map' },
      { id: 'student-planner', icon: 'route', label: 'Route' }
    ]
  };

  function renderNav(role) {
    const nav = document.getElementById('bottomNav');
    if (!isLoggedIn) { nav.innerHTML = ''; return; }
    const items = navConfig[role] || navConfig.student;
    nav.innerHTML = items.map(item => `
      <a class="flex flex-col items-center justify-center text-on-surface-variant tap-hint ${currentPage === item.id ? 'active-tab' : ''}" data-page="${item.id}" onclick="navigateTo('${item.id}')">
        <span class="material-symbols-outlined">${item.icon}</span>
        <span class="text-[10px] font-bold">${item.label}</span>
      </a>
    `).join('');
  }

  function navigateTo(pageId) {
    const target = document.getElementById(pages[pageId]);
    if (!target) return;
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    target.classList.add('active');
    currentPage = pageId;
    document.getElementById('roleDisplay').textContent = isLoggedIn ? (currentRole.charAt(0).toUpperCase() + currentRole.slice(1)) : 'Guest';
    const bottomNav = document.getElementById('bottomNav');
    if (pageId === 'login' || pageId === 'register') {
      bottomNav.style.display = 'none';
    } else {
      bottomNav.style.display = 'flex';
    }
    renderNav(currentRole);
    updateAuthMenu();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function updateAuthMenu() {
    const icon = document.getElementById('authMenuIcon');
    const label = document.getElementById('authMenuLabel');
    const btn = document.getElementById('authMenuBtn');
    if (!icon || !label || !btn) return;
    if (isLoggedIn) {
      icon.textContent = 'logout';
      label.textContent = 'Log Out';
      btn.classList.remove('text-primary', 'hover:bg-secondary-container');
      btn.classList.add('text-error', 'hover:bg-error-container');
    } else {
      icon.textContent = 'login';
      label.textContent = 'Sign In';
      btn.classList.remove('text-error', 'hover:bg-error-container');
      btn.classList.add('text-primary', 'hover:bg-secondary-container');
    }
  }

  function handleAuthMenuClick() {
    document.getElementById('roleMenu').classList.add('hidden');
    if (isLoggedIn) {
      isLoggedIn = false;
      currentRole = 'student';
      showToast('Logged out successfully.');
      navigateTo('login');
    } else {
      navigateTo('login');
    }
  }

  function switchRole(role) {
    currentRole = role;
    document.getElementById('roleDisplay').textContent = role.charAt(0).toUpperCase() + role.slice(1);
    const firstPage = navConfig[role][0].id;
    navigateTo(firstPage);
    document.getElementById('roleMenu').classList.add('hidden');
  }

  function toggleRoleMenu() {
    document.getElementById('roleMenu').classList.toggle('hidden');
  }

  function showToast(msg) {
    const toast = document.getElementById('toast');
    toast.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('show'), 2200);
  }

  function handleLogin() {
    const email = document.getElementById('loginEmail').value.trim();
    const password = document.getElementById('loginPassword').value.trim();
    if (!email || !password) { showToast('Please enter your email and password.'); return; }
    isLoggedIn = true;
    showToast('Welcome back, ' + email.split('@')[0] + '!');
    currentRole = 'student';
    navigateTo('student-home');
    renderNav('student');
  }

  function handleRegister() {
    const name = document.getElementById('regName').value.trim();
    const matric = document.getElementById('regMatric').value.trim();
    const email = document.getElementById('regEmail').value.trim();
    const password = document.getElementById('regPassword').value;
    const confirm = document.getElementById('regConfirmPassword').value;
    const role = document.getElementById('regRole').value;
    if (!name || !matric || !email || !password || !confirm) { showToast('Please fill in all fields.'); return; }
    if (password !== confirm) { showToast('Passwords do not match.'); return; }
    if (password.length < 6) { showToast('Password must be at least 6 characters.'); return; }
    isLoggedIn = true;
    currentRole = role;
    showToast('Account created successfully! Welcome, ' + name + '!');
    const roleMap = { 'student': 'student-home', 'driver': 'driver-dashboard', 'admin': 'admin-dashboard' };
    navigateTo(roleMap[role] || 'student-home');
    renderNav(currentRole);
  }

  function findBestRoute() {
    const origin = document.getElementById('originInput').value.trim();
    const destination = document.getElementById('destinationInput').value.trim();
    if (!origin || !destination) { showToast('Current location or destination is unavailable.'); return; }
    document.getElementById('routeResultTitle').textContent = origin + ' to ' + destination;
    document.getElementById('routeStartLabel').textContent = 'Walk from ' + origin;
    document.getElementById('routeEndLabel').textContent = 'Arrive at ' + destination;
    navigateTo('recommended-route');
  }

  function saveSubscriptions() {
    const enabled = document.querySelectorAll('#page-student-alerts input[type="checkbox"]:checked').length;
    showToast(enabled + ' notification subscriptions saved.');
  }

  function updateGps() {
    const now = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    document.getElementById('gpsTimestamp').textContent = 'GPS database updated at ' + now + ' for Bus #4412';
    showToast('GPS updated successfully.');
  }

  function updateOccupancy(level) {
    const config = {
      Empty: { label: 'Low', percent: 18, badge: 'bg-emerald-600 text-white', text: 'text-emerald-600', bar: 'bg-emerald-600' },
      Moderate: { label: 'Moderate', percent: 54, badge: 'bg-tertiary-container text-white', text: 'text-tertiary', bar: 'bg-tertiary-container' },
      Full: { label: 'Crowded', percent: 92, badge: 'bg-error text-white', text: 'text-error', bar: 'bg-error' }
    }[level];
    const status = document.getElementById('routeAStatus');
    const capacity = document.getElementById('routeACapacity');
    const bar = document.getElementById('routeABar');
    status.className = config.badge + ' text-xs font-bold px-3 py-1 rounded-full';
    status.textContent = config.label;
    capacity.className = 'font-bold ' + config.text;
    capacity.textContent = config.percent + '%';
    bar.className = 'h-full rounded-full ' + config.bar;
    bar.style.width = config.percent + '%';
    document.getElementById('routeAUpdated').textContent = 'Updated just now by driver';
    showToast('Occupancy set to ' + level + '. Student view updated.');
  }

  function sendDelayAlert() {
    const item = document.createElement('div');
    item.className = 'bg-error-container p-3 rounded-xl flex gap-3 tap-hint';
    item.innerHTML = '<div class="w-8 h-8 bg-error text-white rounded-full flex items-center justify-center"><span class="material-symbols-outlined text-sm">warning</span></div><div><p class="font-bold text-sm text-on-error-container">NEW: ROUTE A DELAY</p><p class="text-xs text-on-error-container">Driver reported a 10-min delay. Inbox updated just now.</p></div>';
    document.getElementById('alertInbox').prepend(item);
    showToast('Delay notification sent to subscribed students.');
  }

  function renderStops() {
    const list = document.getElementById('adminStopList');
    list.innerHTML = stops.map(stop => `
      <div class="bg-white p-4 rounded-xl border flex items-center justify-between tap-hint">
        <div><span class="text-xs text-outline">ID: ${stop.id}</span><p class="font-semibold text-on-surface">${stop.name}</p><span class="text-xs text-on-surface-variant">${stop.location}</span></div>
        <div class="flex gap-2">
          <button class="material-symbols-outlined text-primary" onclick="openStopForm(${stop.id})">edit_location</button>
          <button class="material-symbols-outlined text-error" onclick="deleteStop(${stop.id})">delete</button>
        </div>
      </div>
    `).join('');
  }

  function openStopForm(id = null) {
    editingStopId = id;
    const stop = stops.find(s => s.id === id);
    document.getElementById('stopModalTitle').textContent = stop ? 'Edit Bus Stop' : 'Add Bus Stop';
    document.getElementById('stopNameInput').value = stop ? stop.name : '';
    document.getElementById('stopLocationInput').value = stop ? stop.location : '';
    document.getElementById('stopFormError').classList.add('hidden');
    const modal = document.getElementById('stopModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeStopForm() {
    const modal = document.getElementById('stopModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  function saveStop() {
    const name = document.getElementById('stopNameInput').value.trim();
    const location = document.getElementById('stopLocationInput').value.trim();
    if (!name || !location) { document.getElementById('stopFormError').classList.remove('hidden'); return; }
    if (editingStopId) {
      stops = stops.map(s => s.id === editingStopId ? { ...s, name, location } : s);
      showToast('Bus stop information updated successfully.');
    } else {
      stops.unshift({ id: Math.floor(1100 + Math.random() * 800), name, location });
      showToast('New bus stop added successfully.');
    }
    renderStops();
    closeStopForm();
  }

  function deleteStop(id) {
    stops = stops.filter(stop => stop.id !== id);
    renderStops();
    showToast('Bus stop removed from route database.');
  }

  // Initialize
  renderStops();
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-login').classList.add('active');
  document.getElementById('bottomNav').style.display = 'none';
  document.getElementById('roleDisplay').textContent = 'Guest';
  updateAuthMenu();

  document.addEventListener('click', function(e) {
    const menu = document.getElementById('roleMenu');
    if (!menu.contains(e.target) && !e.target.closest('[onclick="toggleRoleMenu()"]')) {
      menu.classList.add('hidden');
    }
  });
</script>

</body>
</html>
