<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>UTM Bus Tracker · 完整高保真原型</title>
  <script>
    window.tailwind = window.tailwind || {};
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            "surface-bright": "#f7f9fb",
            "surface": "#f7f9fb",
            "surface-container-lowest": "#ffffff",
            "surface-container-low": "#f2f4f6",
            "surface-container": "#eceef0",
            "surface-container-high": "#e6e8ea",
            "surface-container-highest": "#e0e3e5",
            "primary": "#004ac6",
            "primary-container": "#2563eb",
            "secondary": "#515f74",
            "secondary-container": "#d5e3fc",
            "tertiary": "#943700",
            "tertiary-container": "#bc4800",
            "tertiary-fixed": "#ffdbcd",
            "secondary-fixed": "#d5e3fc",
            "on-secondary-fixed": "#0a4283",
            "on-tertiary-fixed": "#5c1900",
            "error": "#ba1a1a",
            "error-container": "#ffdad6",
            "outline": "#737686",
            "outline-variant": "#c3c6d7",
            "on-surface": "#191c1e",
            "on-surface-variant": "#434655",
            "on-primary": "#ffffff",
            "on-secondary": "#ffffff",
            "on-secondary-container": "#0a2540",
            "on-tertiary-container": "#ffede6",
            "on-error-container": "#93000a",
            "on-error": "#ffffff"
          }
        }
      }
    };
  </script>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    body { background: #f7f9fb; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
    .fill-icon { font-variation-settings: 'FILL' 1; }
    .glass-panel { background: rgba(255,255,255,0.85); backdrop-filter: blur(12px); border: 1px solid rgba(226,232,240,0.6); }
    .bus-pulse { animation: pulse-ring 1.8s cubic-bezier(0.215,0.61,0.355,1) infinite; }
    @keyframes pulse-ring { 0% { transform: scale(0.8); opacity: 0.7; } 100% { transform: scale(2); opacity: 0; } }
    .page { display: none; animation: fadeUp 0.25s ease; }
    .page.active { display: block; }
    @keyframes fadeUp { 0% { opacity:0.6; transform:translateY(12px); } 100% { opacity:1; transform:translateY(0); } }
    .bottom-nav a { transition: all 0.15s ease; }
    .bottom-nav a.active-tab { background: #d5e3fc; color: #004ac6; border-radius: 9999px; padding: 4px 16px; }
    .bottom-nav a.active-tab .material-symbols-outlined { font-variation-settings: 'FILL' 1; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .tap-hint { transition: transform 0.1s; cursor: pointer; }
    .tap-hint:active { transform: scale(0.97); }
    .role-badge { background: #004ac6; color: white; font-size: 10px; padding: 2px 10px; border-radius: 999px; font-weight: 600; }
    .toast { position: fixed; left: 50%; bottom: 86px; transform: translateX(-50%) translateY(20px); opacity: 0; pointer-events: none; transition: 0.22s ease; z-index: 80; background: #191c1e; color: white; }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* 兜底样式：防止 Tailwind CDN 加载延迟/失败时，主按钮出现白底白字或对比度不足的问题 */
    button.bg-primary { background-color: #004ac6 !important; color: #ffffff !important; }
    button.bg-error { background-color: #ba1a1a !important; color: #ffffff !important; }
    button.bg-secondary { background-color: #515f74 !important; color: #ffffff !important; }
  </style>
</head>
<body>

<div class="max-w-[420px] mx-auto bg-surface-bright min-h-screen relative">

  <!-- ========== Top App Bar ========== -->
  <header class="sticky top-0 z-50 bg-surface/95 backdrop-blur-sm border-b border-outline-variant px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary text-2xl">directions_bus</span>
      <h1 class="font-bold text-primary text-lg tracking-tight">UTM Bus Tracker</h1>
    </div>
    <div class="flex items-center gap-2">
      <span id="roleDisplay" class="role-badge">Student</span>
      <button class="material-symbols-outlined text-on-surface-variant p-1 rounded-full hover:bg-surface-container" onclick="toggleRoleMenu()">expand_more</button>
    </div>
  </header>

  <!-- ========== Role Switcher Dropdown ========== -->
  <div id="roleMenu" class="absolute top-14 right-4 bg-white shadow-xl rounded-xl border border-outline-variant p-2 z-50 hidden w-44">
    <div class="flex flex-col gap-1">
      <button class="text-left px-3 py-2 rounded-lg hover:bg-surface-container text-sm font-medium text-on-surface" onclick="switchRole('student')">👤 Student</button>
      <button class="text-left px-3 py-2 rounded-lg hover:bg-surface-container text-sm font-medium text-on-surface" onclick="switchRole('driver')">🚌 Driver</button>
      <button class="text-left px-3 py-2 rounded-lg hover:bg-surface-container text-sm font-medium text-on-surface" onclick="switchRole('admin')">⚙️ Admin</button>
      <div class="h-px bg-outline-variant my-1"></div>
      <button id="authMenuBtn" class="text-left px-3 py-2 rounded-lg hover:bg-error-container text-sm font-semibold text-error flex items-center gap-2" onclick="handleAuthMenuClick()">
        <span id="authMenuIcon" class="material-symbols-outlined text-base">logout</span>
        <span id="authMenuLabel">Log Out</span>
      </button>
    </div>
  </div>

  <!-- ========== Page Container ========== -->
  <div class="px-4 pb-28 pt-3 space-y-5">

    <!-- ================================ -->
    <!-- ====== Login Page ====== -->
    <!-- ================================ -->
    <div id="page-login" class="page space-y-5">
      <div class="text-center pt-8">
        <span class="material-symbols-outlined text-primary text-6xl">directions_bus</span>
        <h2 class="text-2xl font-bold text-primary mt-2">UTM Bus Tracker</h2>
        <p class="text-on-surface-variant text-sm">Sign in to track campus buses in real time</p>
      </div>
      <div class="bg-white p-6 rounded-xl border shadow-sm space-y-4">
        <div>
          <label class="text-sm font-semibold text-on-surface">Email</label>
          <input id="loginEmail" class="w-full border border-outline-variant rounded-lg px-4 py-3 text-sm mt-1 focus:ring-2 focus:ring-primary focus:border-primary outline-none text-on-surface" placeholder="student@utm.my" type="email" value="alex@utm.my">
        </div>
        <div>
          <label class="text-sm font-semibold text-on-surface">Password</label>
          <input id="loginPassword" class="w-full border border-outline-variant rounded-lg px-4 py-3 text-sm mt-1 focus:ring-2 focus:ring-primary focus:border-primary outline-none text-on-surface" placeholder="••••••••" type="password" value="password123">
        </div>
        <button class="w-full bg-primary text-white py-3 rounded-xl font-bold tap-hint" onclick="handleLogin()">SIGN IN</button>
        <div class="flex items-center gap-4">
          <div class="flex-1 h-px bg-outline-variant"></div>
          <span class="text-xs text-on-surface-variant">OR</span>
          <div class="flex-1 h-px bg-outline-variant"></div>
        </div>
        <button class="w-full bg-secondary-container text-on-secondary-container py-3 rounded-xl font-bold tap-hint" onclick="navigateTo('register')">CREATE NEW ACCOUNT</button>
      </div>
      <div class="text-center text-xs text-on-surface-variant">
        <p>Demo: Use any credentials or click Sign In</p>
      </div>
    </div>

    <!-- ================================ -->
    <!-- ====== Register Page ====== -->
    <!-- ================================ -->
    <div id="page-register" class="page space-y-5">
      <div class="flex items-center gap-2">
        <button class="p-1 rounded-full hover:bg-surface-container" onclick="navigateTo('login')">
          <span class="material-symbols-outlined text-on-surface">arrow_back</span>
        </button>
        <h2 class="font-bold text-lg text-on-surface">Create Account</h2>
      </div>
      <div class="bg-white p-6 rounded-xl border shadow-sm space-y-4">
        <div>
          <label class="text-sm font-semibold text-on-surface">Full Name</label>
          <input id="regName" class="w-full border border-outline-variant rounded-lg px-4 py-3 text-sm mt-1 focus:ring-2 focus:ring-primary focus:border-primary outline-none text-on-surface" placeholder="Alex Johnson" value="Alex Johnson">
        </div>
        <div>
          <label class="text-sm font-semibold text-on-surface">Matric No.</label>
          <input id="regMatric" class="w-full border border-outline-variant rounded-lg px-4 py-3 text-sm mt-1 focus:ring-2 focus:ring-primary focus:border-primary outline-none text-on-surface" placeholder="A24CS0000" value="A24CS0023">
        </div>
        <div>
          <label class="text-sm font-semibold text-on-surface">Email</label>
          <input id="regEmail" class="w-full border border-outline-variant rounded-lg px-4 py-3 text-sm mt-1 focus:ring-2 focus:ring-primary focus:border-primary outline-none text-on-surface" placeholder="student@utm.my" type="email" value="alex@utm.my">
        </div>
        <div>
          <label class="text-sm font-semibold text-on-surface">Password</label>
          <input id="regPassword" class="w-full border border-outline-variant rounded-lg px-4 py-3 text-sm mt-1 focus:ring-2 focus:ring-primary focus:border-primary outline-none text-on-surface" placeholder="••••••••" type="password" value="password123">
        </div>
        <div>
          <label class="text-sm font-semibold text-on-surface">Confirm Password</label>
          <input id="regConfirmPassword" class="w-full border border-outline-variant rounded-lg px-4 py-3 text-sm mt-1 focus:ring-2 focus:ring-primary focus:border-primary outline-none text-on-surface" placeholder="••••••••" type="password" value="password123">
        </div>
        <div>
          <label class="text-sm font-semibold text-on-surface">Role</label>
          <select id="regRole" class="w-full border border-outline-variant rounded-lg px-4 py-3 text-sm mt-1 focus:ring-2 focus:ring-primary focus:border-primary outline-none bg-white text-on-surface">
            <option value="student">Student</option>
            <option value="driver">Bus Driver</option>
            <option value="admin">Administrator</option>
          </select>
        </div>
        <button class="w-full bg-primary text-white py-3 rounded-xl font-bold tap-hint" onclick="handleRegister()">CREATE ACCOUNT</button>
        <p class="text-center text-sm text-on-surface-variant">
          Already have an account?
          <button class="text-primary font-semibold hover:underline" onclick="navigateTo('login')">Sign In</button>
        </p>
      </div>
    </div>

    <!-- ================================ -->
    <!-- ====== Student Role Pages ====== -->
    <!-- ================================ -->

    <!-- Student Home -->
    <div id="page-student-home" class="page space-y-5">
      <div class="bg-primary-container/10 p-5 rounded-2xl border border-primary/20">
        <h2 class="text-2xl font-bold text-primary">Good morning, Alex 👋</h2>
        <p class="text-on-surface-variant text-sm">Ready for your 9:00 AM lecture?</p>
      </div>
      <div class="flex items-center bg-white border border-outline-variant rounded-full px-4 py-3 shadow-sm tap-hint" onclick="navigateTo('student-planner')">
        <span class="material-symbols-outlined text-outline mr-2">search</span>
        <input class="bg-transparent border-none focus:ring-0 w-full text-sm placeholder-on-surface-variant/60 pointer-events-none text-on-surface" placeholder="Where to?" readonly>
        <span class="material-symbols-outlined text-outline ml-2">mic</span>
      </div>
      <!-- Map Preview -->
      <div class="relative h-52 rounded-xl overflow-hidden border border-outline-variant shadow-sm tap-hint" onclick="navigateTo('student-map')">
        <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCLnyTkLfxIjDWHS6UAtZziBDMEvPJ9dWJ1Yi6Y4DIx7RjOAX33_pvHgh6Q4mJ7tdMgkyGIaMhZVZH9a1PUJylgUaJI_N6GpM365WCwgpwT02HcBJhRnwZiK26X7F3PPCnYBP89ysRHvYFFg-e2PX7FQh7FltMpdYLUxiMoGepxlpoyc0wAy5yzCUH-_JMKVOFGFivj_IGuhqOA3nLDfcUfMt9uZLz7PtxUKUcEiFpI7CVLXILIeIZ-eDEFy67CMO65wDnjPZJM1XxW" alt="campus map">
        <div class="absolute bottom-3 left-3 right-3 bg-white/90 backdrop-blur p-3 rounded-xl border flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="bg-primary text-white p-2 rounded-lg"><span class="material-symbols-outlined">directions_bus</span></div>
            <div><p class="font-bold text-primary text-sm">NORTH LOOP · BUS 12</p><p class="text-xs text-on-surface-variant">Arriving in 4 min · Eng. Bldg</p></div>
          </div>
          <span class="text-[10px] font-bold text-green-700 bg-green-50 px-2 py-0.5 rounded-full">LIVE</span>
        </div>
      </div>
      <!-- Quick Access -->
      <div class="grid grid-cols-2 gap-3">
        <div class="col-span-2 bg-white border border-outline-variant p-4 rounded-xl tap-hint flex items-center justify-between" onclick="navigateTo('student-planner')">
          <div class="flex items-center gap-3"><span class="material-symbols-outlined text-secondary">route</span><div><h4 class="font-semibold text-on-surface">Plan Route</h4><p class="text-xs text-on-surface-variant">Pin-to-pin journey</p></div></div>
          <span class="material-symbols-outlined text-outline">arrow_forward_ios</span>
        </div>
        <div class="bg-white border border-outline-variant p-4 rounded-xl tap-hint" onclick="navigateTo('student-occupancy')">
          <div class="flex justify-between"><span class="material-symbols-outlined text-secondary">groups</span><span class="bg-secondary-container text-on-secondary-container text-xs font-bold px-2 py-0.5 rounded-full">MODERATE</span></div>
          <p class="font-semibold text-sm text-on-surface mt-2">Live Occupancy</p>
          <div class="w-full bg-surface-container h-1.5 rounded-full mt-1"><div class="bg-secondary h-1.5 rounded-full w-[65%]"></div></div>
        </div>
        <div class="bg-white border border-outline-variant p-4 rounded-xl tap-hint" onclick="navigateTo('student-alerts')">
          <div class="flex justify-between"><span class="material-symbols-outlined text-tertiary">warning</span><span class="w-2 h-2 bg-tertiary rounded-full animate-pulse"></span></div>
          <p class="font-semibold text-sm text-on-surface mt-2">Route A Detour</p>
          <p class="text-[11px] text-on-surface-variant">Construction on Main St.</p>
        </div>
      </div>
      <!-- Favorites -->
      <div><p class="font-semibold text-sm text-on-surface mb-2">Favorites</p>
        <div class="flex gap-2 overflow-x-auto no-scrollbar">
          <div class="flex-shrink-0 bg-white border px-4 py-2 rounded-lg flex items-center gap-2 tap-hint"><span class="material-symbols-outlined text-primary fill-icon">home</span><span class="text-on-surface">Home to Quad</span></div>
          <div class="flex-shrink-0 bg-white border px-4 py-2 rounded-lg flex items-center gap-2 tap-hint"><span class="material-symbols-outlined text-secondary">school</span><span class="text-on-surface">Tech Plaza</span></div>
          <div class="flex-shrink-0 bg-white border px-4 py-2 rounded-lg flex items-center gap-2 tap-hint"><span class="material-symbols-outlined text-outline">add</span><span class="text-on-surface">Add New</span></div>
        </div>
      </div>
    </div>

    <!-- Student Live Map (UC001, UC003) -->
    <div id="page-student-map" class="page space-y-4">
      <div class="flex items-center gap-2"><button class="p-1 rounded-full hover:bg-surface-container" onclick="navigateTo('student-home')"><span class="material-symbols-outlined text-on-surface">arrow_back</span></button><h2 class="font-bold text-lg text-on-surface">Live Tracking</h2></div>
      <div class="relative h-72 rounded-xl overflow-hidden border border-outline-variant">
        <img class="w-full h-full object-cover opacity-80" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBcJC_qVGPKXAjJ2R5n38d6V8POZpvYwr7cXqzrrtvh56fi8vZO30UI8b-zftSJH-Ixxw9s-klIN5fms-xJKhQ7MyilsiOdpecSbBuWNS7E173sGQRX8nfZRONfRfOEwTeNgcnjy7Ystn9YzP4mQNwR7xlcfpJ2TAwVrJh8rDUWYrcwO025xhl9jiMUidSpaUV2pKP1tG26MfpQQdp9AmzvJSOWYqF7asA800L8s6xu_4CD8NeP_3XvvN7Gl8pV0O4o_q0lyHgaT331" alt="map">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"><div class="relative"><div class="bus-pulse absolute w-12 h-12 bg-secondary-container rounded-full opacity-40"></div><div class="bg-secondary-container w-10 h-10 rounded-full flex items-center justify-center border-2 border-white shadow-lg relative z-10"><span class="material-symbols-outlined text-on-secondary-container fill-icon">directions_bus</span></div></div></div>
        <div class="absolute bottom-4 left-4 right-4 glass-panel p-3 rounded-xl flex justify-between items-center">
          <div><p class="text-xs font-bold text-primary">North Loop · Bus #402</p><p class="text-sm font-semibold text-on-surface">ETA: 5:42</p></div>
          <span class="bg-error-container text-on-error-container text-xs font-bold px-3 py-1 rounded-full">ON TIME</span>
        </div>
      </div>
      <div class="bg-white p-4 rounded-xl border"><div class="flex items-center justify-between"><span class="bg-tertiary-container text-on-tertiary-container px-3 py-0.5 rounded-full text-xs font-bold">Arriving Next</span><span class="text-2xl font-bold text-on-surface">5:42</span></div><p class="text-sm text-on-surface-variant flex items-center gap-1"><span class="material-symbols-outlined text-sm">location_on</span> North Loop · Vehicle #402</p></div>
      <div class="space-y-2">
        <div class="flex items-center justify-between bg-white p-3 rounded-xl border tap-hint"><div class="flex items-center gap-3"><div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center font-bold text-primary">B</div><div><p class="font-semibold text-sm text-on-surface">Route B · Express</p><p class="text-xs text-on-surface-variant">To South Quad</p></div></div><div class="text-right"><p class="font-bold text-primary">12 <span class="text-xs">min</span></p><span class="text-[10px] bg-tertiary-fixed text-on-tertiary-fixed px-1.5 py-0.5 rounded font-bold">ON TIME</span></div></div>
        <div class="flex items-center justify-between bg-white p-3 rounded-xl border tap-hint"><div class="flex items-center gap-3"><div class="w-10 h-10 bg-surface-container-high rounded-lg flex items-center justify-center font-bold text-primary">A</div><div><p class="font-semibold text-sm text-on-surface">Route A · North Loop</p><p class="text-xs text-on-surface-variant">To Engineering Heights</p></div></div><div class="text-right"><p class="font-bold text-on-surface">25 <span class="text-xs">min</span></p><span class="text-[10px] bg-secondary-fixed text-on-secondary-fixed px-1.5 py-0.5 rounded font-bold">Delayed</span></div></div>
      </div>
      <button class="w-full bg-primary text-white py-3 rounded-xl font-bold flex items-center justify-center gap-2 tap-hint" onclick="navigateTo('student-planner')"><span class="material-symbols-outlined">directions</span> GET DIRECTIONS</button>
    </div>

    <!-- Student Route Planner (UC004, UC005) -->
    <div id="page-student-planner" class="page space-y-4">
      <div class="flex items-center gap-2"><button class="p-1 rounded-full hover:bg-surface-container" onclick="navigateTo('student-home')"><span class="material-symbols-outlined text-on-surface">arrow_back</span></button><h2 class="font-bold text-lg text-on-surface">Plan Route</h2></div>
      <div class="bg-white p-5 rounded-xl border shadow-sm relative">
        <div class="absolute left-[18px] top-10 bottom-10 w-0.5 border-l-2 border-dashed border-outline-variant"></div>
        <div class="flex items-center gap-3 mb-5"><div class="w-6 h-6 rounded-full border-2 border-primary bg-white z-10 flex items-center justify-center"><div class="w-2 h-2 rounded-full bg-primary"></div></div><div class="flex-1"><label class="text-xs font-bold text-outline">Origin</label><input id="originInput" class="w-full bg-surface-container-low border rounded-lg px-3 py-2 text-sm text-on-surface" value="Engineering Hall"></div></div>
        <div class="flex items-center gap-3"><div class="w-6 h-6 rounded-full bg-primary z-10 flex items-center justify-center"><span class="material-symbols-outlined text-white text-sm">location_on</span></div><div class="flex-1"><label class="text-xs font-bold text-outline">Destination</label><input id="destinationInput" class="w-full bg-surface-container-low border rounded-lg px-3 py-2 text-sm text-on-surface" value="Student Union"></div></div>
      </div>
      <button class="w-full bg-primary text-white py-3 rounded-xl font-bold tap-hint" onclick="findBestRoute()">FIND BEST ROUTE</button>
      <div class="grid grid-cols-2 gap-2">
        <div class="bg-white p-3 rounded-xl border tap-hint"><span class="material-symbols-outlined text-primary">history</span><p class="font-semibold text-sm text-on-surface">Main Library</p><p class="text-xs text-on-surface-variant">2 min walk</p></div>
        <div class="bg-white p-3 rounded-xl border tap-hint"><span class="material-symbols-outlined text-tertiary fill-icon">star</span><p class="font-semibold text-sm text-on-surface">Gym & Rec</p><p class="text-xs text-on-surface-variant">North Campus</p></div>
        <div class="col-span-2 bg-white p-3 rounded-xl border flex items-center justify-between tap-hint"><div class="flex items-center gap-3"><span class="material-symbols-outlined text-outline">work</span><div><p class="font-semibold text-sm text-on-surface">Science Lab Annex</p><p class="text-xs text-on-surface-variant">Frequent Route</p></div></div><span class="material-symbols-outlined text-outline">chevron_right</span></div>
      </div>
      <!-- Optimal Path Preview -->
      <div class="relative h-40 rounded-xl overflow-hidden border tap-hint" onclick="navigateTo('stop-detail')">
        <img class="w-full h-full object-cover opacity-70" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBfg-xNy68MaNQj6kQc8oygfsxKZUd8cl2Wt56_2l9A5SFrq1QmV3nv1zAemlnX5rQymC8DESQ9lAjSIP9RuWOTdMlMiut-4zMnlF5SLnYKSottEpmNFFOnGsmhUDRqSR755WkswhWv4Hh0Pf2WJ75nMrdmI7Xb1LFFB_n18d3HaUlPOmSGqH1PPBQLBingGKnILDJ1cqGxqXwCxAGw0yqJFRIpo88UFr6PSWShgPoUOr3eARjRBvZrYvadKG52hp4ewq9_dR4lLAt_" alt="map">
        <div class="absolute bottom-2 left-2 right-2 glass-panel p-2 rounded-xl flex justify-between items-center">
          <span><span class="font-bold text-sm text-on-surface">Optimal Path</span><span class="text-xs block text-on-surface-variant">12 min · Bus + walk</span></span>
          <span class="bg-primary text-white text-xs font-bold px-3 py-1 rounded-full">FASTEST</span>
        </div>
